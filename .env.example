# 硅基世界环境配置示例
# 复制此文件为 .env 并填写真实值

# ==============================================================================
# 网络配置
# ==============================================================================

# Sepolia 测试网 (推荐)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
SEPOLIA_CHAIN_ID=11155111

# 本地开发 (Hardhat)
LOCAL_RPC_URL=http://127.0.0.1:8545
LOCAL_CHAIN_ID=31337

# ==============================================================================
# 部署配置
# ==============================================================================

# 部署者私钥 (⚠️ 不要提交到 Git!)
DEPLOYER_PRIVATE_KEY=0x_your_private_key_here

# Etherscan API Key (用于合约验证)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Alchemy API Key (可选，如果用 Alchemy RPC)
ALCHEMY_API_KEY=your_alchemy_key

# ==============================================================================
# 代币配置
# ==============================================================================

INITIAL_SUPPLY=1000000
TOKEN_NAME="Silicon World Token"
TOKEN_SYMBOL="SWT"

# ==============================================================================
# NexusA 配置
# ==============================================================================

NEXUSA_API_URL=https://api.nexusa.io
NEXUSA_CONTRACT_ADDRESS=

# ==============================================================================
# 后端配置
# ==============================================================================

DATABASE_URL=sqlite:///./silicon_world.db
SECRET_KEY=your-secret-key-here
DEBUG=True

# ==============================================================================
# 前端配置
# ==============================================================================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CONTRACT_ADDRESS=
